<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nova AI</title>
    <link rel="stylesheet" href="style.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;700&display=swap" rel="stylesheet">
</head>
<body>

    <!-- شريط التنقل (Navbar) -->
    <header>
        <div class="container navbar">
            <div class="logo">Nova<span>AI</span></div>
            <nav>
                <ul class="nav-links">
                    <li><a href="index.html">الرئيسية</a></li>
                    <li><a href="services.html" class="active">الخدمات</a></li>
<li><a href="contact.html">اتصل بنا</a></li>
                </ul>
            </nav>
        </div>
    </header>

    <!-- قسم عنوان الصفحة (Page Header) -->
    <section class="page-header">
        <div class="container">
            <h1>خدماتنا الذكية</h1>
            <p>هاي جميع الميزات الذكاء الصطناعي الي موجوده في الموقع نوفا.</p>
        </div>
    </section>

    <!-- قسم الخدمات (Services Section) -->
    <section class="services-page-content">
        <div class="container">
            <div class="services-grid">
                
                <!-- الخدمة الأولى: توليد المحتوى -->
                <div class="card">
                    <div class="card-icon">🎨</div>
                    <h3>توليد الفنون والصور</h3>
                    <p>تحويل الأفكار والوصف النصي إلى صور رقمية وتصاميم إبداعية فائقة الدقة خلال ثوانٍ معدودة.</p>
                </div>

                <!-- الخدمة الثانية: شات بوت -->
                <div class="card">
                    <div class="card-icon">💬</div>
                    <h3>مساعدو الدردشة الذكية</h3>
                    <p>بناء وتطوير بوتات خدمة عملاء (Chatbots) تفاعلية تفهم اللغات المختلفة وتجيب على مدار الساعة.</p>
                </div>

                <!-- الخدمة الثالثة: كتابة المحتوى -->
                <div class="card">
                    <div class="card-icon">📝</div>
                    <h3>صناعة المحتوى الآلي</h3>
                    <p>توليد مقالات احترافية، نصوص إعلانية، ومحتوى تسويقي متوافق تماماً مع محركات البحث (SEO).</p>
                </div>

                <!-- الخدمة الرابعة: الأتمتة -->
                <div class="card">
                    <div class="card-icon">⚙️</div>
                    <h3>أتمتة العمليات الذكية</h3>
                    <p>ربط الأنظمة وبرمجتها لإنجاز المهام الروتينية المتكررة تلقائياً لرفع كفاءة وسرعة أعمالك.</p>
                </div>

            </div>
        </div>
    </section>

    <!-- تذييل الصفحة (Footer) -->
    <footer>
        <p>&copy; 2026 جميع الحقوق محفوظة لموقع AI. تم التصميم بكل ذكاء.</p>
    </footer>

</body>
</html>
/* إعدادات عامة */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Cairo', sans-serif;
}

:root {
    --bg-color: #0b0f19;
    --card-bg: #151c2c;
    --primary-color: #6366f1;
    --secondary-color: #a855f7;
    --text-color: #f3f4f6;
    --text-muted: #9ca3af;
}

body {
    background-color: var(--bg-color);
    color: var(--text-color);
    overflow-x: hidden;
}

.container {
    width: 85%;
    max-width: 1200px;
    margin: 0 auto;
}

/* تحديث شريط التنقل للتوسيط الكامل */
header {
    background-color: rgba(11, 15, 25, 0.8);
    backdrop-filter: blur(10px);
    position: fixed;
    width: 100%;
    top: 0;
    z-index: 100;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
}

.navbar {
    display: flex;
    justify-content: space-between; /* يحافظ على الشعار في طرفه */
    align-items: center;
    padding: 20px 0;
    position: relative; /* ضرورية ليعمل التوسيط المطلق للقائمة بداخلها */
}

/* تكبير حجم الشعار (اللوجو) */
.logo {
    font-size: 28px; /* كانت 24px */
    font-weight: 700;
    letter-spacing: 1px;
}

/* تكبير حجم روابط القائمة وزيادة المسافة بينها */
.nav-links {
    display: flex;
    list-style: none;
    gap: 40px; /* زدت المسافة بين الكلمات من 30px لـ 40px لتكون مريحة أكثر */
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
}

.nav-links a {
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.3s;
    font-size: 18px; /* ضفنا حجم الخط هنا لتكبير الروابط */
    font-weight: 700; /* جعلنا الخط عريض (Bold) ليبدو أوضح وأجمل */
}
.nav-links a:hover, .nav-links a.active {
    color: var(--primary-color);
}
/* الأزرار */
.btn {
    display: inline-block;
    padding: 10px 24px;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 700;
    transition: all 0.3s ease;
}

.btn-nav {
    background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
    color: white;
}

.btn-primary {
    background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
    color: white;
    box-shadow: 0 4px 15px rgba(99, 102, 241, 0.4);
}

.btn-secondary {
    background: transparent;
    color: white;
    border: 1px solid rgba(255, 255, 255, 0.2);
}

.btn:hover {
    transform: translateY(-2px);
    opacity: 0.9;
}

/* القسم الرئيسي (Hero) */
.hero {
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    background: radial-gradient(circle at center, rgba(99, 102, 241, 0.15) 0%, transparent 60%);
    padding-top: 80px;
}

.hero-content h1 {
    font-size: 48px;
    line-height: 1.4;
    margin-bottom: 20px;
}

.hero-content h1 span {
    background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
}

.hero-content p {
    color: var(--text-muted);
    font-size: 18px;
    max-width: 600px;
    margin: 0 auto 40px auto;
    line-height: 1.6;
}

.hero-buttons {
    display: flex;
    justify-content: center;
    gap: 20px;
}

/* قسم الخدمات */
.services {
    padding: 100px 0;
}

.section-title {
    text-align: center;
    font-size: 32px;
    margin-bottom: 60px;
    position: relative;
}

.section-title::after {
    content: '';
    display: block;
    width: 60px;
    height: 4px;
    background: var(--primary-color);
    margin: 10px auto 0 auto;
    border-radius: 2px;
}

.services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 30px;
}

.card {
    background-color: var(--card-bg);
    padding: 40px 30px;
    border-radius: 12px;
    transition: all 0.3s ease;
    border: 1px solid rgba(255, 255, 255, 0.03);
}

.card:hover {
    transform: translateY(-10px);
    border-color: rgba(99, 102, 241, 0.3);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
}

.card-icon {
    font-size: 40px;
    margin-bottom: 20px;
}

.card h3 {
    font-size: 22px;
    margin-bottom: 15px;
}

.card p {
    color: var(--text-muted);
    font-size: 15px;
    line-height: 1.6;
}

/* التذييل */
footer {
    text-align: center;
    padding: 40px 0;
    color: var(--text-muted);
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    font-size: 14px;
}

/* التوافق مع الشاشات الصغيرة */
@media (max-width: 768px) {
    .nav-links, .btn-nav {
        display: none; /* لإبقاء التصميم بسيطاً على الهواتف بدون تعقيد JS */
    }
    .hero-content h1 {
        font-size: 32px;
    }
    .hero-buttons {
        flex-direction: column;
        gap: 15px;
    }
}

-----------------------------------------------services.html---------------------

/* تنسيق خاص بصفحة الخدمات المستقلة */
.page-header {
    padding: 150px 0 50px 0;
    text-align: center;
    background: radial-gradient(circle at top, rgba(168, 85, 247, 0.1) 0%, transparent 50%);
}

.page-header h1 {
    font-size: 40px;
    margin-bottom: 15px;
    background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
}

.page-header p {
    color: var(--text-muted);
    font-size: 16px;
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
}

.services-page-content {
    padding: 60px 0 100px 0;
}

-----------------------------------------------contact.html---------------------



/* تنسيقات صفحة اتصل بنا */
.contact-section {
    padding: 40px 0 100px 0;
}

.contact-container {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 50px;
    align-items: start;
}

/* صندوق معلومات الاتصال */
.contact-info {
    background-color: var(--card-bg);
    padding: 40px;
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.03);
}

.contact-info h3 {
    font-size: 24px;
    margin-bottom: 10px;
    color: var(--text-color);
}

.info-desc {
    color: var(--text-muted);
    font-size: 14px;
    margin-bottom: 30px;
}

.info-item {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 25px;
}

.info-icon {
    font-size: 28px;
    background: rgba(99, 102, 241, 0.1);
    padding: 10px;
    border-radius: 8px;
    width: 50px;
    height: 50px;
    display: flex;
    align-items: center;
    justify-content: center;
}

.info-item h4 {
    font-size: 16px;
    margin-bottom: 2px;
}

.info-item p {
    color: var(--text-muted);
    font-size: 14px;
}

/* تصميم النموذج (Form) */
.contact-form {
    background-color: var(--card-bg);
    padding: 40px;
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.03);
    display: flex;
    flex-direction: column;
    gap: 20px;
}

.form-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.form-group label {
    font-size: 14px;
    color: var(--text-color);
    font-weight: 700;
}

.form-group input, .form-group textarea {
    background-color: #0b0f19;
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 12px 15px;
    border-radius: 8px;
    color: white;
    font-family: 'Cairo', sans-serif;
    font-size: 14px;
    transition: border-color 0.3s;
}

.form-group input:focus, .form-group textarea:focus {
    outline: none;
    border-color: var(--primary-color);
}

.btn-block {
    width: 100%;
    border: none;
    cursor: pointer;
    font-size: 16px;
    padding: 14px;
}

/* التوافق مع الهواتف */
@media (max-width: 900px) {
    .contact-container {
        grid-template-columns: 1fr;
        gap: 30px;
    }
}


<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nova AI</title>
    <link rel="stylesheet" href="style.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;700&display=swap" rel="stylesheet">
</head>
<style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Cairo', sans-serif;
        }

        :root {
            --bg-color: #0b0f19;
            --card-bg: #151c2c;
            --sidebar-bg: #0f1524;
            --primary-color: #6366f1;
            --secondary-color: #a855f7;
            --text-color: #f3f4f6;
            --text-muted: #9ca3af;
            --active-chat: rgba(99, 102, 241, 0.15);
            --danger-color: #ef4444;
            --success-color: #10b981;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-color);
            display: flex;
            height: 100vh;
            overflow: hidden;
            position: relative;
        }

        /* --- التعديل الخرافي الجديد: تكبير الضوء لأقصى درجة وزيادة قوته ووضوحه --- */
        body::before {
            content: "";
            position: absolute;
            top: 30%; /* رفعه للأعلى للشمال أكثر */
            left: 35%; 
            transform: translate(-50%, -50%);
            width: 1200px; /* تكبير الحجم بشكل هائل من 800px إلى 1200px ليغطي الخلفية بالكامل */
            height: 1200px;
            /* زيادة opacity الألوان لـ 0.28 و 0.12 ليصبح الضوء واضح جداً ومشبع */
            background: radial-gradient(circle, rgba(168, 85, 247, 0.28) 0%, rgba(99, 102, 241, 0.12) 40%, transparent 70%);
            pointer-events: none; 
            z-index: 0;
            filter: blur(60px); /* زيادة التمويه للحفاظ على انسيابية ونعومة الإضاءة العملاقة */
        }

        /* --- القائمة الجانبية (Sidebar) --- */
        .sidebar {
            width: 280px;
            background-color: var(--sidebar-bg);
            border-left: 1px solid rgba(255, 255, 255, 0.05);
            display: flex;
            flex-direction: column;
            padding: 15px;
            height: 100%;
            position: relative;
            z-index: 2;
        }

        .user-badge {
            background: rgba(255, 255, 255, 0.03);
            padding: 10px;
            border-radius: 8px;
            margin-bottom: 15px;
            font-size: 13px;
            border: 1px solid rgba(255, 255, 255, 0.05);
            color: var(--text-muted);
            text-align: center;
        }
        .user-badge strong { color: white; }

        .new-chat-btn {
            background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
            color: white;
            border: none;
            padding: 12px;
            border-radius: 10px;
            font-size: 15px;
            font-weight: bold;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            margin-bottom: 15px;
        }

        .about-me-container {
            margin-bottom: 15px;
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 8px;
            overflow: hidden;
        }

        .about-me-toggle {
            width: 100%;
            background: none;
            border: none;
            color: var(--text-color);
            padding: 10px;
            font-size: 13px;
            font-weight: bold;
            text-align: right;
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            align-items: center;
            transition: background 0.3s;
        }
        .about-me-toggle:hover { background: rgba(255, 255, 255, 0.03); }

        .about-me-content {
            display: none;
            padding: 10px;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
            flex-direction: column;
            gap: 8px;
        }

        .about-me-content textarea {
            width: 100%;
            height: 70px;
            background-color: var(--bg-color);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 6px;
            color: white;
            padding: 8px;
            font-size: 12px;
            resize: none;
            outline: none;
            font-family: 'Cairo', sans-serif;
        }

        .save-about-btn {
            background-color: var(--primary-color);
            color: white;
            border: none;
            padding: 6px;
            border-radius: 4px;
            font-size: 12px;
            font-weight: bold;
            cursor: pointer;
            transition: opacity 0.3s;
        }
        .save-about-btn:hover { opacity: 0.9; }

        .history-title {
            font-size: 12px;
            color: var(--text-muted);
            margin-bottom: 10px;
            font-weight: bold;
        }

        .chats-list {
            flex: 1;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .chat-item {
            padding: 10px 12px;
            background-color: rgba(255, 255, 255, 0.02);
            border-radius: 8px;
            cursor: pointer;
            font-size: 14px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            transition: all 0.3s;
            border: 1px solid transparent;
            gap: 10px;
        }

        .chat-item-text {
            flex: 1;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .chat-item:hover, .chat-item.active {
            background-color: var(--active-chat);
            border-color: rgba(99, 102, 241, 0.3);
            color: white;
        }

        .delete-chat-btn {
            background: none;
            border: none;
            color: var(--text-muted);
            cursor: pointer;
            font-size: 14px;
            padding: 2px 5px;
            border-radius: 4px;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .delete-chat-btn:hover {
            color: #f87171;
            background-color: rgba(239, 68, 68, 0.15);
        }

        .sidebar-footer {
            padding-top: 15px;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .home-btn {
            background-color: rgba(99, 102, 241, 0.1);
            color: #a5b4fc;
            border: 1px solid rgba(99, 102, 241, 0.2);
            padding: 10px;
            border-radius: 8px;
            cursor: pointer;
            font-size: 14px;
            font-weight: bold;
            text-align: center;
            text-decoration: none;
            transition: all 0.3s;
        }
        .home-btn:hover {
            background-color: rgba(99, 102, 241, 0.2);
            color: white;
        }

        .logout-btn {
            background-color: rgba(239, 68, 68, 0.1);
            color: #f87171;
            border: 1px solid rgba(239, 68, 68, 0.2);
            padding: 10px;
            border-radius: 8px;
            cursor: pointer;
            font-size: 14px;
            font-weight: bold;
            text-align: center;
            transition: all 0.3s;
        }
        .logout-btn:hover { background-color: rgba(239, 68, 68, 0.2); }

        /* --- منطقة الشات الرئيسية --- */
        .main-chat {
            flex: 1;
            display: flex;
            flex-direction: column;
            background-color: transparent; 
            height: 100%;
            position: relative;
            z-index: 1;
        }

        .ai-header {
            padding: 20px;
            background-color: rgba(21, 28, 44, 0.6); /* زيادة الشفافية لتجعل الضوء العملاق يسطع من الخلف */
            backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .ai-header h2 { font-size: 18px; }
        .ai-header h2 span { color: var(--primary-color); }

        .header-controls {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .voice-selector {
            background-color: var(--bg-color);
            color: var(--text-color);
            border: 1px solid rgba(255, 255, 255, 0.1);
            padding: 8px 12px;
            border-radius: 8px;
            font-size: 13px;
            outline: none;
            cursor: pointer;
            font-family: 'Cairo', sans-serif;
        }

        .voice-selector option {
            background-color: var(--card-bg);
        }

        .call-btn {
            background-color: rgba(16, 185, 129, 0.1);
            color: var(--success-color);
            border: 1px solid rgba(16, 185, 129, 0.2);
            padding: 8px 16px;
            border-radius: 20px;
            cursor: pointer;
            font-weight: bold;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: all 0.3s;
        }
        .call-btn.in-call {
            background-color: rgba(239, 68, 68, 0.2);
            color: var(--danger-color);
            border-color: rgba(239, 68, 68, 0.3);
            animation: pulse 1.5s infinite;
        }

        .chat-box {
            flex: 1;
            padding: 20px;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 20px;
            background: transparent;
        }

        .message {
            max-width: 75%;
            padding: 14px 18px;
            border-radius: 12px;
            line-height: 1.6;
            font-size: 15px;
            word-wrap: break-word;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
        }

        .message.bot { background-color: rgba(21, 28, 44, 0.8); border: 1px solid rgba(255, 255, 255, 0.05); align-self: flex-start; border-top-right-radius: 2px;}
        .message.user { background: linear-gradient(135deg, var(--primary-color), var(--secondary-color)); color: white; align-self: flex-end; border-top-left-radius: 2px;}
        .message.error { background-color: rgba(239, 68, 68, 0.1); color: #f87171; align-self: center; font-size: 13px; }

        .input-area {
            padding: 20px;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
            background-color: rgba(21, 28, 44, 0.6);
            backdrop-filter: blur(12px);
        }

        .input-wrapper {
            display: flex;
            gap: 12px;
            max-width: 900px;
            margin: 0 auto;
            width: 100%;
            align-items: center;
        }

        .input-wrapper input {
            flex: 1;
            background-color: var(--bg-color);
            border: 1px solid rgba(255, 255, 255, 0.1);
            padding: 14px 20px;
            border-radius: 10px;
            color: white;
            outline: none;
        }

        .voice-btn {
            background-color: rgba(255, 255, 255, 0.03);
            color: var(--text-muted);
            border: 1px solid rgba(255, 255, 255, 0.1);
            width: 48px;
            height: 48px;
            border-radius: 10px;
            cursor: pointer;
            font-size: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s;
        }
        .voice-btn.recording {
            background-color: rgba(239, 68, 68, 0.2);
            color: var(--danger-color);
            border-color: var(--danger-color);
            animation: pulse 1.5s infinite;
        }

        .send-btn {
            background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
            color: white;
            border: none;
            height: 48px;
            padding: 0 24px;
            border-radius: 10px;
            font-weight: 700;
            cursor: pointer;
        }

        @keyframes pulse {
            0% { transform: scale(1); }
            50% { transform: scale(1.04); box-shadow: 0 0 15px rgba(239, 68, 68, 0.4); }
            100% { transform: scale(1); }
        }

        @media (max-width: 768px) {
            body { flex-direction: column; }
            .sidebar { width: 100%; height: auto; max-height: 320px; border-left: none; border-bottom: 1px solid rgba(255, 255, 255, 0.05); overflow-y: auto;}
            body::before { width: 500px; height: 500px; top: 35%; left: 50%; }
        }
    </style>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;700&display=swap" rel="stylesheet">
</head>
<body>

    <div class="sidebar">
        <div class="user-badge" id="userBadge">مرحباً، <strong>مستخدم</strong></div>
        <button class="new-chat-btn" onclick="startNewChat()">📝 محادثة جديدة</button>
        
        <div class="about-me-container">
            <button class="about-me-toggle" onclick="toggleAboutMePanel()">👤 عرّفني عن نفسك <span id="aboutArrow">▼</span></button>
            <div class="about-me-content" id="aboutMeContent">
                <textarea id="aboutMeText" placeholder="اكتب هنا ماذا تحب، ماذا تكره، مجال عملك، أو كيف ترغب أن يناديك الـ AI..."></textarea>
                <button class="save-about-btn" onclick="saveAboutMeData()">حفظ البيانات 💾</button>
            </div>
        </div>

        <div class="history-title">محادثاتك الحالية</div>
        <div class="chats-list" id="chatsList"></div>
        
        <div class="sidebar-footer">
            <a href="index.html" class="home-btn" onclick="stopLiveCallUI()">🏠 الصفحة الرئيسية</a>
            <button class="logout-btn" onclick="handleLogout()">تسجيل الخروج 🚪</button>
        </div>
    </div>

    <div class="main-chat">
        <div class="ai-header">
            <h2>🤖 مساعد <span>NovaAI</span> المباشر</h2>
            
            <div class="header-controls">
                <select id="genderVoiceSelect" class="voice-selector" onchange="window.speechSynthesis.cancel()">
                    <option value="female">👤 صوت أنثى</option>
                    <option value="male">👨 صوت ذكر</option>
                </select>
                <button class="call-btn" id="callBtn" onclick="toggleLiveCall()">📞 مكالمة صوتية</button>
            </div>
        </div>
        <div class="chat-box" id="chatBox"></div>
        <div class="input-area">
            <div class="input-wrapper">
                <button class="voice-btn" id="voiceBtn" onclick="toggleVoiceRecord()">🎙️</button>
                <input type="text" id="userInput" placeholder="اكتب سؤالك أو استخدم الفويس..." onkeypress="checkEnter(event)">
                <button class="send-btn" onclick="sendMessage()">إرسال ✨</button>
            </div>
        </div>
    </div>

    <script>
        let currentUser = JSON.parse(localStorage.getItem('nova_current_user')) || null;
        let userChats = {};
        let currentChatId = "";
        
        let recognition;
        let isRecording = false;
        let isCallActive = false;
        let shouldKeepListening = false;

        window.onload = function() {
            if (!currentUser) {
                window.location.href = "index.html";
                return;
            }
            document.getElementById('userBadge').innerHTML = `مرحباً، <strong>${currentUser.name}</strong>`;
            
            userChats = JSON.parse(localStorage.getItem(`chats_${currentUser.email}`)) || {};
            currentChatId = localStorage.getItem(`current_id_${currentUser.email}`) || "";

            const savedAbout = localStorage.getItem(`about_${currentUser.email}`) || "";
            document.getElementById('aboutMeText').value = savedAbout;

            if (Object.keys(userChats).length === 0 || !currentChatId) {
                startNewChat();
            } else {
                renderSidebar();
                loadChat(currentChatId);
            }

            initSpeechRecognition();
            
            if (typeof speechSynthesis !== 'undefined' && speechSynthesis.onvoiceschanged !== undefined) {
                speechSynthesis.onvoiceschanged = () => {};
            }
        };

        function toggleAboutMePanel() {
            const panel = document.getElementById('aboutMeContent');
            const arrow = document.getElementById('aboutArrow');
            if (panel.style.display === 'flex') {
                panel.style.display = 'none';
                arrow.innerText = '▼';
            } else {
                panel.style.display = 'flex';
                arrow.innerText = '▲';
            }
        }

        function saveAboutMeData() {
            const text = document.getElementById('aboutMeText').value.trim();
            localStorage.setItem(`about_${currentUser.email}`, text);
            alert("تم حفظ بيانات اهتماماتك بنجاح! الـ AI سيعتمد عليها في الردود القادمة البطل. ⚡");
            toggleAboutMePanel();
        }

        function getSystemPrompt(isCall = false) {
            const personalInfo = localStorage.getItem(`about_${currentUser.email}`) || "";
            let basePrompt = "أنت مساعد ذكي واسمك NovaAI وتجيب دائما باللغة العربية باختصار وسرعة.";
            
            if (isCall) {
                basePrompt = "أنت مساعد ذكي في مكالمة صوتية حية. أجب دائماً باللغة العربية باختصار شديد ومباشر (سطر واحد فقط).";
            }

            if (personalInfo) {
                basePrompt += `\nمعلومات هامة جداً عن المستخدم يجب أن تبني إجابتك وتفضيلاتك وتعاملك معها بناءً عليها: [ ${personalInfo} ]`;
            }
            return basePrompt;
        }

        function initSpeechRecognition() {
            window.SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
            if (window.SpeechRecognition) {
                recognition = new SpeechRecognition();
                recognition.continuous = false;
                recognition.lang = 'ar-SA';
                recognition.interimResults = false;

                recognition.onresult = function(event) {
                    const resultText = event.results[0][0].transcript;
                    if (isCallActive) {
                        sendLiveCallMessage(resultText);
                    } else {
                        document.getElementById('userInput').value = resultText;
                        stopVoiceUI();
                    }
                };

                recognition.onerror = function() {
                    if (isCallActive && shouldKeepListening) {
                        try { recognition.start(); } catch(e){}
                    }
                };

                recognition.onend = function() {
                    if (isRecording) stopVoiceUI();
                    if (isCallActive && shouldKeepListening && !window.speechSynthesis.speaking) {
                        try { recognition.start(); } catch(e){}
                    }
                };
            }
        }

        function toggleVoiceRecord() {
            if (!recognition) {
                alert("متصفحك لا يدعم التعرف على الصوت.");
                return;
            }
            if (isRecording) {
                recognition.stop();
                stopVoiceUI();
            } else {
                if (isCallActive) toggleLiveCall();
                isRecording = true;
                document.getElementById('voiceBtn').classList.add('recording');
                document.getElementById('userInput').placeholder = "جاري الاستماع لصوتك... تكلم الآن";
                recognition.start();
            }
        }

        function stopVoiceUI() {
            isRecording = false;
            document.getElementById('voiceBtn').classList.remove('recording');
            document.getElementById('userInput').placeholder = "اكتب سؤالك أو استخدم الفويس...";
        }

        function toggleLiveCall() {
            if (!recognition) {
                alert("متصفحك لا يدعم المكالمات الصوتية الذكية.");
                return;
            }
            if (isCallActive) {
                stopLiveCallUI();
            } else {
                if (isRecording) toggleVoiceRecord();
                isCallActive = true;
                shouldKeepListening = true;
                document.getElementById('callBtn').classList.add('in-call');
                document.getElementById('callBtn').innerText = "🛑 إنهاء المكالمة";
                speakText("أهلاً بك، تم بدء الاتصال بنجاح. أنا أستمع إليك الآن تفضل.");
                
                setTimeout(() => {
                    if (isCallActive) {
                        try { recognition.start(); } catch(e){}
                    }
                }, 4000);
            }
        }

        function stopLiveCallUI() {
            isCallActive = false;
            shouldKeepListening = false;
            window.speechSynthesis.cancel();
            if (recognition) {
                try { recognition.stop(); } catch(e){}
            }
            document.getElementById('callBtn').classList.remove('in-call');
            document.getElementById('callBtn').innerText = "📞 مكالمة صوتية";
        }

        function speakText(text) {
            window.speechSynthesis.cancel();
            const utterance = new SpeechSynthesisUtterance(text);
            utterance.lang = 'ar-SA';
            
            const selectedGender = document.getElementById('genderVoiceSelect').value;
            const voices = window.speechSynthesis.getVoices();
            
            let arabicVoices = voices.filter(voice => voice.lang.includes('ar'));
            let targetVoice = null;

            if (selectedGender === 'female') {
                targetVoice = arabicVoices.find(v => 
                    v.name.toLowerCase().includes('female') || 
                    v.name.toLowerCase().includes('mady') || 
                    v.name.toLowerCase().includes('zayd') ||
                    v.name.includes('ليلى') || v.name.includes('مريم') || v.name.includes('زينة')
                );
                utterance.pitch = 1.35; 
                utterance.rate = 1.05; 
            } else {
                targetVoice = arabicVoices.find(v => 
                    v.name.toLowerCase().includes('male') || 
                    v.name.toLowerCase().includes('naim') ||
                    v.name.includes('ماجد') || v.name.includes('طارق')
                );
                utterance.pitch = 0.70; 
                utterance.rate = 0.90; 
            }

            if (targetVoice) {
                utterance.voice = targetVoice;
            } else if (arabicVoices.length > 0) {
                utterance.voice = arabicVoices[0];
            }

            utterance.onend = function() {
                if (isCallActive && shouldKeepListening) {
                    try { recognition.start(); } catch(e){}
                }
            };
            
            window.speechSynthesis.speak(utterance);
        }

        async function sendLiveCallMessage(text) {
            if (text.trim() === '') return;
            
            printMessage('user', text);
            userChats[currentChatId].messages.push({ role: "user", text: text });

            try {
                const systemPrompt = getSystemPrompt(true);
                const encodedPrompt = encodeURIComponent(`${systemPrompt}\nالمستخدم: ${text}`);
                
                const response = await fetch(`https://text.pollinations.ai/${encodedPrompt}?model=openai&cache=false`);
                const aiResponseText = await response.text();
                const cleanReply = aiResponseText.trim();

                printMessage('bot', cleanReply);
                userChats[currentChatId].messages.push({ role: "bot", text: cleanReply });
                saveUserData();
                
                speakText(cleanReply);

            } catch (error) {
                if (isCallActive && shouldKeepListening) {
                    speakText("عذراً، أعد المحاولة.");
                }
            }
        }

        function printMessage(role, text) {
            const chatBox = document.getElementById('chatBox');
            const msgDiv = document.createElement('div');
            msgDiv.className = `message ${role}`;
            msgDiv.innerText = text;
            chatBox.appendChild(msgDiv);
            chatBox.scrollTop = chatBox.scrollHeight;
        }

        function handleLogout() {
            stopLiveCallUI();
            localStorage.removeItem('nova_current_user');
            window.location.href = "index.html";
        }

        function startNewChat() {
            const id = 'chat_' + Date.now();
            userChats[id] = {
                title: "محادثه جديده",
                messages: [{ role: "bot", text: `أهلاً بك يا ${currentUser.name}! كيف يمكنني مساعدتك اليوم؟ ⚡` }]
            };
            currentChatId = id;
            saveUserData();
            renderSidebar();
            loadChat(id);
        }

        function deleteChat(chatId, event) {
            event.stopPropagation();
            if (confirm("هل أنت متأكد من رغبتك في حذف هذه المحادثة نهائياً؟")) {
                if (isCallActive && currentChatId === chatId) { stopLiveCallUI(); }
                delete userChats[chatId];
                saveUserData();
                if (currentChatId === chatId) {
                    const remainingChatIds = Object.keys(userChats);
                    if (remainingChatIds.length > 0) { currentChatId = remainingChatIds[0]; } 
                    else { startNewChat(); return; }
                }
                renderSidebar();
                loadChat(currentChatId);
            }
        }

        function saveUserData() {
            if (currentUser) {
                localStorage.setItem(`chats_${currentUser.email}`, JSON.stringify(userChats));
                localStorage.setItem(`current_id_${currentUser.email}`, currentChatId);
            }
        }

        function renderSidebar() {
            const listContainer = document.getElementById('chatsList');
            listContainer.innerHTML = "";
            const sortedIds = Object.keys(userChats).sort((a, b) => b.split('_')[1] - a.split('_')[1]);

            sortedIds.forEach(id => {
                const item = document.createElement('div');
                item.className = `chat-item ${id === currentChatId ? 'active' : ''}`;
                item.onclick = () => { if(!isCallActive) loadChat(id); };

                const textSpan = document.createElement('span');
                textSpan.className = 'chat-item-text';
                textSpan.innerText = userChats[id].title;

                const deleteBtn = document.createElement('button');
                deleteBtn.className = 'delete-chat-btn';
                deleteBtn.innerHTML = '🗑️';
                deleteBtn.title = 'حذف المحادثة';
                deleteBtn.onclick = (e) => deleteChat(id, e);

                item.appendChild(textSpan);
                item.appendChild(deleteBtn);
                listContainer.appendChild(item);
            });
        }

        function loadChat(id) {
            currentChatId = id;
            saveUserData();
            renderSidebar();

            const chatBox = document.getElementById('chatBox');
            chatBox.innerHTML = "";

            if (userChats[id] && userChats[id].messages) {
                userChats[id].messages.forEach(msg => {
                    printMessage(msg.role, msg.text);
                });
            }
        }

        async function sendMessage() {
            const inputElement = document.getElementById('userInput');
            const messageText = inputElement.value.trim();
            if (messageText === '') return;

            if (userChats[currentChatId].title === "محادثه جديده") {
                userChats[currentChatId].title = messageText.substring(0, 22) + (messageText.length > 22 ? "..." : "");
                renderSidebar();
            }

            printMessage('user', messageText);
            userChats[currentChatId].messages.push({ role: "user", text: messageText });
            inputElement.value = '';

            const chatBox = document.getElementById('chatBox');
            const loadingDiv = document.createElement('div');
            loadingDiv.className = 'message bot';
            loadingDiv.innerText = "جاري الكتابة... ⚡";
            chatBox.appendChild(loadingDiv);
            chatBox.scrollTop = chatBox.scrollHeight;

            try {
                const systemPrompt = getSystemPrompt(false);
                const encodedPrompt = encodeURIComponent(`${systemPrompt}\nالمستخدم: ${messageText}`);
                
                const response = await fetch(`https://text.pollinations.ai/${encodedPrompt}?model=openai&cache=false`);
                const aiResponseText = await response.text();
                
                if (chatBox.contains(loadingDiv)) { chatBox.removeChild(loadingDiv); }

                const cleanReply = aiResponseText.trim();
                printMessage('bot', cleanReply);
                userChats[currentChatId].messages.push({ role: "bot", text: cleanReply });
                saveUserData();

            } catch (error) {
                if (chatBox.contains(loadingDiv)) { chatBox.removeChild(loadingDiv); }
                printMessage('error', "⚠️ حدث خطأ، يرجى إعادة المحاولة.");
            }
        }

        function checkEnter(event) { if (event.key === 'Enter') { sendMessage(); } }
    </script>
</body>
</html>
